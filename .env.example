# Copy to .env and fill in. Never commit .env.

# --- Database ---
POSTGRES_USER=ksp
POSTGRES_PASSWORD=ksp_local_dev
POSTGRES_DB=ksp_crime
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Host-side port (change if 5432 is taken locally)
POSTGRES_HOST_PORT=5432

# --- Anthropic ---
ANTHROPIC_API_KEY=
ORCHESTRATION_MODEL=claude-opus-4-8
BULK_MODEL=claude-sonnet-5

# --- Bhashini (Phase 5, leave blank until P23) ---
BHASHINI_USER_ID=
BHASHINI_API_KEY=

# --- App ---
BACKEND_PORT=8000
FRONTEND_PORT=5173
LOG_LEVEL=INFO
